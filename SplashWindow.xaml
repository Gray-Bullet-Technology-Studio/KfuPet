<Window
    x:Class="KfuPet.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="KfuPet - Loading">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image x:Name="LogoImage"
                   Source="Assets/icon/Startlogo.png"
                   Width="155"
                   Height="155"
                   Stretch="Uniform"
                   Opacity="0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="0.5" ScaleY="0.5"/>
                </Image.RenderTransform>
            </Image>

            <Grid Width="400" Height="50" Margin="0,20,0,0">
                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,400,50"/>
                </Grid.Clip>

                <!-- "你的智能桌面伙伴"（底层，初始偏左被遮罩覆盖，向右滑动露出） -->
                <TextBlock x:Name="SubtitleText"
                           Text="你的智能桌面伙伴"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="SubtitleTransform" X="-32"/>
                    </TextBlock.RenderTransform>
                </TextBlock>

                <!-- 遮罩（中层，初始偏左覆盖"你的智能桌面伙伴"，右端与KfuPet右端对齐） -->
                <Rectangle x:Name="SubtitleMask"
                           Width="200" Height="50"
                           HorizontalAlignment="Left"
                           Margin="60,0,0,0">
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="MaskTransform" X="0"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- "KfuPet"（顶层，向左滑动） -->
                <TextBlock x:Name="TitleText"
                           Text="KfuPet"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Opacity="0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TitleTransform" Y="-30"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </StackPanel>

        <TextBlock x:Name="VersionText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,30"
                   FontSize="14"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Opacity="0"/>

        <Grid.Resources>
            <Storyboard x:Name="FadeInStoryboard">
                <!-- Logo 淡入 + 缩放 -->
                <DoubleAnimation
                    Storyboard.TargetName="LogoImage"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1"
                    Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="LogoScale"
                    Storyboard.TargetProperty="ScaleX"
                    From="0.5" To="1"
                    Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="LogoScale"
                    Storyboard.TargetProperty="ScaleY"
                    From="0.5" To="1"
                    Duration="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- 版本号淡入 -->
                <DoubleAnimation
                    Storyboard.TargetName="VersionText"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1"
                    Duration="0:0:0.5"
                    BeginTime="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- "KfuPet" 从上方滑下 + 淡入 -->
                <DoubleAnimation
                    Storyboard.TargetName="TitleTransform"
                    Storyboard.TargetProperty="Y"
                    From="-30" To="0"
                    Duration="0:0:0.5"
                    BeginTime="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="TitleText"
                    Storyboard.TargetProperty="Opacity"
                    From="0" To="1"
                    Duration="0:0:0.5"
                    BeginTime="0:0:0.8">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>

                <!-- "KfuPet" 和遮罩同步向左滑，"你的智能桌面伙伴" 向右滑露出 -->
                <DoubleAnimation
                    Storyboard.TargetName="TitleTransform"
                    Storyboard.TargetProperty="X"
                    From="0" To="-82"
                    Duration="0:0:0.6"
                    BeginTime="0:0:1.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="MaskTransform"
                    Storyboard.TargetProperty="X"
                    From="0" To="-82"
                    Duration="0:0:0.6"
                    BeginTime="0:0:1.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                    Storyboard.TargetName="SubtitleTransform"
                    Storyboard.TargetProperty="X"
                    From="-32" To="50"
                    Duration="0:0:0.6"
                    BeginTime="0:0:1.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="FadeOutStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="RootGrid"
                    Storyboard.TargetProperty="Opacity"
                    From="1" To="0"
                    Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>
    </Grid>
</Window>
